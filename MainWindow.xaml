<Window x:Class="InternetSharePro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2000/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2000/xaml"
        Title="Internet Share Pro" Height="520" Width="420" 
        Background="#1E1E1E" Foreground="#FFFFFF" FontFamily="Segoe UI"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="INTERNET SHARE PRO" FontSize="22" FontWeight="Bold" Foreground="#0078D4" HorizontalAlignment="Center"/>
            <Separator Background="#333333" Margin="0,10,0,0"/>
        </StackPanel>
        <StackPanel Grid.Row="1" VerticalAlignment="Top">
            <TextBlock Text="Internet do PC" FontSize="11" Foreground="#888888" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,15">
                <Ellipse Width="10" Height="10" Fill="#107C41" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="TxtPcInternet" Text="Conectado" FontSize="15" FontWeight="SemiBold"/>
            </StackPanel>
            <TextBlock Text="Celular (Android)" FontSize="11" Foreground="#888888" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,15">
                <Ellipse x:Name="DotCelularStatus" Width="10" Height="10" Fill="#D83B01" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="TxtCelularStatus" Text="Verificando dispositivo..." FontSize="15" FontWeight="SemiBold"/>
            </StackPanel>
            <TextBlock Text="Modo de Transmissão (PC → Celular)" FontSize="11" Foreground="#888888" Margin="0,5,0,6" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <RadioButton x:Name="RadioUsb" Content="Cabo USB (Reverse Tethering)" IsChecked="True" Foreground="White" Margin="0,0,20,0"/>
                <RadioButton x:Name="RadioWifi" Content="Wi-Fi Hotspot" Foreground="White"/>
            </StackPanel>
            <TextBlock Text="Métricas de Conexão" FontSize="11" Foreground="#888888" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <Border BorderBrush="#333333" BorderThickness="1" CornerRadius="5" Padding="12" Background="#252525">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Download (PC)" FontSize="11" Foreground="#888888"/>
                        <TextBlock x:Name="TxtDownload" Text="⬇ 120 Mbps" FontSize="16" FontWeight="Bold" Foreground="#0078D4" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Upload (PC)" FontSize="11" Foreground="#888888"/>
                        <TextBlock x:Name="TxtUpload" Text="⬆ 35 Mbps" FontSize="16" FontWeight="Bold" Foreground="#107C41" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
        <StackPanel Grid.Row="2">
            <Button x:Name="BtnCompartilhar" Content="Compartilhar Internet" Background="#0078D4" Foreground="White" FontWeight="Bold" FontSize="15" Padding="12" BorderThickness="0" Cursor="Hand" Click="BtnCompartilhar_Click"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,5">
                <TextBlock Text="Status do App: " Foreground="#888888" FontSize="12"/>
                <TextBlock x:Name="TxtStatusGeral" Text="Pronto para iniciar" FontWeight="SemiBold" Foreground="#0078D4" FontSize="12"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
